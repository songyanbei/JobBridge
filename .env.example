# ============================================================================
# JobBridge 环境变量配置模板
# 使用方法：复制为 .env 后填入真实值
# ============================================================================

# ---- 应用 ----
APP_ENV=development                   # development / production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-random-64-chars

# 容器与进程时区。APScheduler / loguru / MySQL 都依赖此值。
# 不设置 → 镜像内使用 Dockerfile 默认（Asia/Shanghai）。
TZ=Asia/Shanghai

# ---- 数据库 MySQL 8.0+ ----
DB_HOST=localhost                       # 生产环境 docker 内用 mysql（compose service name）
DB_PORT=3306
DB_NAME=jobbridge
DB_USER=jobbridge
DB_PASSWORD=jobbridge                   # 生产环境必须改强密码
DB_ROOT_PASSWORD=root                   # 生产环境必须改强密码

# ---- Redis 7+ ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50               # 连接池上限，按并发量调整

# ---- 企业微信 ----
# 从企业微信管理后台获取
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_AES_KEY=

# ---- LLM 供应商 ----
# 见方案 §4.3 LLM 抽象层
# provider 可选: qwen / doubao / local
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_API_BASE=
LLM_INTENT_MODEL=qwen-turbo
LLM_RERANKER_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=30

# ---- 对象存储 ----
# 见方案 §4.2（一期选型待定）
OSS_PROVIDER=local                    # local / aliyun / tencent / minio
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_LOCAL_DIR=uploads                 # 本地存储目录（OSS_PROVIDER=local 时生效）
OSS_LOCAL_URL_PREFIX=/files           # 本地文件 URL 前缀

# ---- 运营后台鉴权 ----
ADMIN_JWT_SECRET=change-me-to-random-64-chars
ADMIN_JWT_EXPIRES_HOURS=24

# 强制首登改密：true 时管理员未改默认密码前，除 /admin/me 与 /admin/me/password
# 之外的接口一律返回 40301。生产部署前**必须**保持 true，避免 admin/admin123 被滥用。
ADMIN_FORCE_PASSWORD_CHANGE=true

# ---- CORS ----
# 逗号分隔的允许域名列表，为空时开发环境允许全部，生产环境拒绝全部
# 生产示例：CORS_ORIGINS=https://admin.example.com,https://www.example.com
# 注意：APP_ENV=production 时不得为空或包含 "*"，启动会直接报错退出
CORS_ORIGINS=

# ---- 事件回传 API（Phase 5） ----
# 小程序点击事件回传使用的 API Key，与 JWT 分离；生产环境每季度轮换。
EVENT_API_KEY=

# ============================================================================
# Phase 7：定时任务 / 监控 / 日报
# ============================================================================

# APScheduler 使用的时区（cron 表达式按此解释）
SCHEDULER_TIMEZONE=Asia/Shanghai

# 接收日报 / 告警的企微群 chatid；为空时仅写 loguru，不推送群
DAILY_REPORT_CHAT_ID=

# 队列积压告警阈值（queue:incoming 超过则告警）
MONITOR_QUEUE_INCOMING_THRESHOLD=50

# 出站重试队列积压阈值（queue:send_retry / queue:group_send_retry）
MONITOR_SEND_RETRY_THRESHOLD=20

# 告警去重窗口（同一事件 N 秒内只推送一次企微群）
MONITOR_ALERT_DEDUPE_SECONDS=600

