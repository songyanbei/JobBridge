# ============================================================================
# JobBridge 环境变量配置模板
# 使用方法：复制为 .env 后填入真实值
# ============================================================================

# ---- 应用 ----
APP_ENV=development                   # development / production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-random-64-chars

# ---- 数据库 MySQL 8.0+ ----
DB_HOST=localhost                       # 生产环境 docker 内用 mysql（compose service name）
DB_PORT=3306
DB_NAME=jobbridge
DB_USER=jobbridge
DB_PASSWORD=jobbridge                   # 生产环境必须改强密码
DB_ROOT_PASSWORD=root                   # 生产环境必须改强密码

# ---- Redis 7+ ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- 企业微信 ----
# 从企业微信管理后台获取
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_AES_KEY=

# ---- LLM 供应商 ----
# 见方案 §4.3 LLM 抽象层
# provider 可选: qwen / doubao / local
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_API_BASE=
LLM_INTENT_MODEL=qwen-turbo
LLM_RERANKER_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=30

# ---- 对象存储 ----
# 见方案 §4.2（一期选型待定）
OSS_PROVIDER=local                    # local / aliyun / tencent / minio
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=

# ---- 运营后台鉴权 ----
ADMIN_JWT_SECRET=change-me-to-random-64-chars
ADMIN_JWT_EXPIRES_HOURS=24

# ---- CORS ----
# 逗号分隔的允许域名列表，为空时开发环境允许全部，生产环境拒绝全部
# 生产示例：CORS_ORIGINS=https://admin.example.com,https://www.example.com
CORS_ORIGINS=
