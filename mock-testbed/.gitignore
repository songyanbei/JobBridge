# Dependencies
**/node_modules/
**/.venv/
**/venv/
**/__pycache__/
**/*.pyc
**/*.pyo

# Env files
**/.env
!**/.env.example

# Build artifacts
**/dist/
**/build/
**/*.egg-info/

# Runtime
logs/*.log
logs/*.pid
!logs/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# pytest
.pytest_cache/
**/pytest-cache-files-*/
.coverage
htmlcov/

# Stray venv artifacts if `python -m venv .` was run in backend/ by mistake
backend/bin/
backend/lib/
backend/lib64/
backend/pyvenv.cfg
backend/include/
backend/share/
