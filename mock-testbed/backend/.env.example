# ========================================================================
# Mock 企业微信测试台 · 后端配置示例
# 复制为 .env 并按实际环境调整；切勿提交真实 .env 到仓库
# ========================================================================

# 共享主后端的 MySQL（只读 user 表 + 写 wecom_inbound_event）
MOCK_DB_DSN=mysql+pymysql://root:password@localhost:3306/jobbridge

# 共享主后端的 Redis（用于 rpush queue:incoming + pub/sub mock:outbound:*）
MOCK_REDIS_URL=redis://localhost:6379/0

# 本服务监听端口（默认 8001，避免与主后端 8000 冲突）
MOCK_PORT=8001

# 允许的前端源（沙箱前端 dev 默认跑 5174）
MOCK_CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# 模拟企业微信的 corp_id（仅字段演示，不校验）
MOCK_CORPID=wwmock_corpid

# 模拟的 agent_id（仅字段演示）
MOCK_AGENTID=1000002
